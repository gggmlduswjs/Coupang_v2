# ===== Database =====
# 개발: SQLite, 프로덕션: PostgreSQL (Supabase)
DATABASE_URL=sqlite:///./data/coupang.db
# DATABASE_URL=postgresql://user:password@host:5432/coupang_biz

# ===== Obsidian Vault =====
OBSIDIAN_VAULT_PATH=G:\내 드라이브\Obsidian

# ===== Coupang WING API (계정별) =====
# 007-ez
COUPANG_007EZ_VENDOR_ID=your-vendor-id
COUPANG_007EZ_ACCESS_KEY=your-access-key
COUPANG_007EZ_SECRET_KEY=your-secret-key

# 002-bm
COUPANG_002BM_VENDOR_ID=your-vendor-id
COUPANG_002BM_ACCESS_KEY=your-access-key
COUPANG_002BM_SECRET_KEY=your-secret-key

# 007-bm
COUPANG_007BM_VENDOR_ID=your-vendor-id
COUPANG_007BM_ACCESS_KEY=your-access-key
COUPANG_007BM_SECRET_KEY=your-secret-key

# 007-book
COUPANG_007BOOK_VENDOR_ID=your-vendor-id
COUPANG_007BOOK_ACCESS_KEY=your-access-key
COUPANG_007BOOK_SECRET_KEY=your-secret-key

# big6ceo
COUPANG_BIG6CEO_VENDOR_ID=your-vendor-id
COUPANG_BIG6CEO_ACCESS_KEY=your-access-key
COUPANG_BIG6CEO_SECRET_KEY=your-secret-key

# ===== Coupang 계정 로그인 (Playwright) =====
ACCOUNT_1_NAME=007-ez
ACCOUNT_1_EMAIL=your@email.com
ACCOUNT_1_PASSWORD=your-password

ACCOUNT_2_NAME=002-bm
ACCOUNT_2_EMAIL=your@email.com
ACCOUNT_2_PASSWORD=your-password

ACCOUNT_3_NAME=007-bm
ACCOUNT_3_EMAIL=your@email.com
ACCOUNT_3_PASSWORD=your-password

ACCOUNT_4_NAME=007-book
ACCOUNT_4_EMAIL=your@email.com
ACCOUNT_4_PASSWORD=your-password

ACCOUNT_5_NAME=big6ceo
ACCOUNT_5_EMAIL=your@email.com
ACCOUNT_5_PASSWORD=your-password

# ===== Encryption =====
ENCRYPTION_KEY=your-encryption-key-here

# ===== Crawler Settings =====
CRAWL_DELAY_MIN=3.0
CRAWL_DELAY_MAX=7.0
CRAWL_MAX_ITEMS_PER_SESSION=100
CRAWL_TIMEOUT=30

# ===== Playwright (검색 수집) =====
HEADLESS=false
MAX_PAGES=3
CHROME_DEBUG_PORT=9222

# ===== Upload Settings =====
UPLOAD_DELAY_MIN=5.0
UPLOAD_DELAY_MAX=10.0
UPLOAD_MAX_DAILY_PER_ACCOUNT=20

# ===== Analysis Settings =====
ANALYSIS_PERIOD_DAYS=7
ANALYSIS_EXPOSURE_LOW_THRESHOLD=10
ANALYSIS_CONVERSION_LOW_THRESHOLD=50

# ===== Notification =====
ENABLE_KAKAO_NOTIFICATION=false
KAKAO_API_KEY=

ENABLE_EMAIL_NOTIFICATION=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your@email.com
EMAIL_SMTP_PASSWORD=your-app-password

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Redis (선택, Celery) =====
# REDIS_URL=redis://localhost:6379/0
